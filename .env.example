# Husker — variables d'environnement
# Copier en `.env` (gitignore) et adapter les valeurs : cp .env.example .env

# DB SQLite — requis (panic au démarrage si absent).
# Aussi utilisé à la COMPILATION par les macros sqlx::query_as! :
# la DB pointée doit exister et avoir les migrations appliquées.
DATABASE_URL=sqlite:husker.db

# Port d'écoute du serveur axum — optionnel (défaut : 8080).
PORT=8080
